<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atmosphere | A Silent Harbor</title>
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,300,0,0" />
</head>
<body>
    <!--Search overlay-->
    <div class="search-overlay active">
        <nav class="search-overlay-nav">
            <div class="close-btn">
                <span class="material-symbols-outlined">close</span>
            </div>
        </nav>
<!-- Main Canvas -->
        <main class="canvas">
        
            <div class="content-wrapper">
            
                <!-- Create Post Card -->
                <div class="glass-card">
                
                    <h1 class="create-post-header">Create your atmosphere</h1>
                
                    <!-- Title -->
                    <input type="text" class="title-input" placeholder="Title your reflection...">
                
                    <!-- Toolbar -->
                    <div class="toolbar">
                        <span class="material-symbols-outlined">format_bold</span>
                        <span class="material-symbols-outlined">format_italic</span>
                        <span class="material-symbols-outlined">format_list_bulleted</span>
                        <span class="material-symbols-outlined">format_quote</span>
                        <span class="material-symbols-outlined">image</span>
                        <span class="material-symbols-outlined">link</span>
                    </div>
                
                    <!-- Body -->
                    <textarea class="body-input" placeholder="What is on your mind? Let it drift into the atmosphere..."></textarea>
                
                    <!-- Mood Selection -->
                    <h3 class="label-caps" style="margin-top:30px; color:  rgba(195, 198, 209, 0.7); font-weight: 100;">Select Your Glow</h3>
                
                    <div class="mood-grid">
                    
                        <div class="mood-btn">
                            <div class="indicator"></div>
                            <strong style="font-weight: 100;">Calm</strong>
                            <p class="body-md">Peaceful thoughts and quiet observations.</p>
                        </div>
                    
                        <div class="mood-btn">
                            <div class="indicator" style="background:#FFD6A5;"></div>
                            <strong style="font-weight: 100;">Warmth</strong>
                            <p class="body-md">Moments of joy and gratitude.</p>
                        </div>
                    
                        <div class="mood-btn">
                            <div class="indicator" style="background:#BDB2FF;"></div>
                            <strong style="font-weight: 100;">Reflective</strong>
                            <p class="body-md">Deep thoughts and inner growth.</p>
                        </div>
                    
                    </div>
                
                    <!-- Actions -->
                    <div style="margin-top:30px; display:flex; gap:16px;">
                        <button class="send-btn" style="width:100%; border-radius:50px;">
                            Release
                        </button>
                    
                        <button class="send-btn" style="width:100%; border-radius:50px; background:transparent; border:1px solid rgba(255,255,255,0.2); color:white;">
                            Save
                        </button>
                    </div>
                
                </div>
            
                <!-- Sidebar -->
                <aside>
                
                    <!-- Rules -->
                    <div class="glass-card">
                        <h3 class="label-caps">Sanctuary Rules</h3>
                    
                        <p class="body-md"><strong>Maintain Anonymity</strong><br>
                        Never share personal info.</p>
                        
                        <p class="body-md"><strong>Echo Kindness</strong><br>
                        Keep things respectful.</p>
                        
                        <p class="body-md"><strong>Safe Harbor</strong><br>
                        No hate or harassment.</p>
                    </div>
                
                    <!-- Tip -->
                    <div class="glass-card" style="margin-top:20px;">
                        <p class="body-md italic">
                            "Your thoughts are like clouds. Watch them pass."
                        </p>
                    </div>
                
                </aside>
            
            </div>
        
        </main>
    </div>



    <!-- Background Layers -->
    <div class="mesh-gradient"></div>
    <div class="aurora-orb orb-1"></div>
    <div class="aurora-orb orb-2"></div>

    <!-- Top Navigation -->
    <nav class="top-nav">
        <div class="logo">ATMOSPHERE</div>
        <div class="nav-actions">
            <span class="material-symbols-outlined icon-blue">settings</span>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        <!-- Hero Section -->
        <header class="hero">
            <h1 class="display-lg">ATMOSPHERE</h1>
            <p class="body-md hero-subtitle">
                A silent harbor for your drifting thoughts. Breathe, reflect, and find stillness in the collective hum of existence.
            </p>
        </header>

        <!-- Bento Grid (6 Cards) -->
        <section class="grid-container">
            
            <!-- 1. Tall Reflection -->
            <article class="card card-tall aurora-blue">
                <span class="material-symbols-outlined icon-blue">bedtime</span>
                <p class="title-sm italic">"The warmth of finding comfort in an old song that used to be a stranger."</p>
                <div class="tag">MELANCHOLY</div>
            </article>

            <!-- 2. Small Observation -->
            <article class="card card-small aurora-peach">
                <p class="body-md">Watching the rain fall on a quiet Sunday afternoon... everything feels paused.</p>
            </article>

            <!-- 3. Atmospheric Visual -->
            <article class="card card-media">
                <div class="media-overlay">
                    <span class="label-caps">Current Drift</span>
                </div>
            </article>

            <!-- 4. Large Headline Thought -->
            <article class="card card-large aurora-purple">
                <div class="avatar-circle">
                    <span class="material-symbols-outlined">self_improvement</span>
                </div>
                <h2 class="headline-md">"Realizing that I am not the storm, but the space where the storm happens."</h2>
                <span class="label-caps dimmed">Shared 2m ago</span>
            </article>

            <!-- 5. Sensory Detail -->
            <article class="card card-small-alt aurora-blue">
                <p class="body-md italic">The smell of woodsmoke and crisp autumn air...</p>
            </article>

            <!-- 6. Collective Stat -->
            <article class="card card-stat aurora-peach">
                <span class="material-symbols-outlined icon-peach">forum</span>
                <span class="label-caps dimmed">42 Souls Reflecting</span>
            </article>

        </section>
    </main>
    <!-- Fixed Bottom Input -->
    <div class="input-container">
        <div class="search-bar">
            <input class="search-input" type="text" placeholder="Release a thought into the void...">
            <button class="send-btn">
                <span class="material-symbols-outlined">north</span>
            </button>
        </div>
    </div>

    <!-- Bottom Navigation -->
    <nav class="bottom-nav">
        <a href="#" class="nav-item active">
            <span class="material-symbols-outlined">home</span>
            <span class="nav-label">Home</span>
        </a>
        <a href="#" class="nav-item">
            <span class="material-symbols-outlined">self_improvement</span>
            <span class="nav-label">Reflect</span>
        </a>
        <a href="#" class="nav-item">
            <span class="material-symbols-outlined">Hive</span>
            <span class="nav-label">Community</span>
        </a>
        <a href="#" class="nav-item">
            <span class="material-symbols-outlined">account_circle</span>
            <span class="nav-label">Profile</span>
        </a>
    </nav>
<script src="/js/index.js"></script>
</body>
</html>